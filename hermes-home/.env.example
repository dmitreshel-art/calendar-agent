# ── Hermes Agent Environment ────────────────────────────
# Copy this file to data/hermes/.env or fill values through:
#   docker compose run --rm hermes setup
#   docker compose run --rm hermes gateway setup

# ── LLM provider ─────────────────────────────────────────
# Choose one provider in setup and fill the corresponding key.
OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Matrix gateway ───────────────────────────────────────
# Use official Hermes variable names.
MATRIX_HOMESERVER=https://org1.company.ru
MATRIX_USER_ID=@calendar-agent:org1.company.ru
# Prefer MATRIX_ACCESS_TOKEN for production. Password login also works.
MATRIX_ACCESS_TOKEN=
# MATRIX_PASSWORD=

# Restrict who can interact with the bot. Comma-separated full Matrix IDs.
MATRIX_ALLOWED_USERS=@dmitry:org1.company.ru

# E2EE is required for this deployment.
MATRIX_ENCRYPTION=true
# Stable device ID helps keep the crypto store/device identity predictable.
MATRIX_DEVICE_ID=HERMES_CALENDAR_AGENT
# Strongly recommended when Element cross-signing is enabled.
# Find it in Element: Settings → Security & Privacy → Encryption → Security Key.
MATRIX_RECOVERY_KEY=

# Room behavior.
MATRIX_REQUIRE_MENTION=true
MATRIX_AUTO_THREAD=true
MATRIX_REACTIONS=true

# Optional: home room for proactive reminders/cron notifications.
# MATRIX_HOME_ROOM=!roomid:org1.company.ru
