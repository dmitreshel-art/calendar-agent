# Calendar Agent MVP configuration
APP_NAME=calendar-agent
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8080

# SQLite database path inside container
DATABASE_URL=sqlite:////app/data/app.db

# REST API tokens. Generate with: openssl rand -hex 32
AGENT_API_TOKEN=replace-with-random-agent-token
ADMIN_API_TOKEN=replace-with-random-admin-token

# Matrix federation admission
AUTO_PROVISION_EMPLOYEES=true
ALLOWED_MATRIX_SERVERS=org1.company.ru,org2.company.ru,org-main.company.ru
DISABLE_UNKNOWN_HOMESERVERS=true
BLOCKED_MATRIX_USERS=@calendar-bot:org-main.company.ru,@monitoring:org1.company.ru

# Default employee settings
DEFAULT_TIMEZONE=Europe/Moscow
DEFAULT_WORKDAY_START=09:00
DEFAULT_WORKDAY_END=18:00
DEFAULT_WORKDAYS=MO,TU,WE,TH,FR
DEFAULT_REMINDER_MINUTES=15
DEFAULT_FREEBUSY_WORKDAYS=5
MAX_FREE_SLOTS=3

# Radicale / CalDAV
RADICALE_URL=http://radicale:5232
RADICALE_USERNAME=calendar-service
RADICALE_PASSWORD=replace-with-random-radicale-password
RADICALE_CALENDAR_ROOT=/calendars
RADICALE_STRICT_WRITES=true

# Built-in Radicale htpasswd credentials for docker-compose demo.
# Defaults to RADICALE_USERNAME/RADICALE_PASSWORD if omitted.
RADICALE_HTPASSWD_USER=calendar-service
RADICALE_HTPASSWD_PASSWORD=replace-with-random-radicale-password

# MCP server configuration
MCP_ENABLED=true
MCP_TRANSPORT=stdio
